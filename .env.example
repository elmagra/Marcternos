# Panel web
PORT=3000
NODE_ENV=production

# Multi-instance & catalog
MULTI_INSTANCE_ENABLED=true
DYNAMIC_CATALOG_ENABLED=true
DEFAULT_INSTANCE_ID=default

# Paths (defaults work inside Docker)
SERVERS_ROOT=/app/data/servers
INSTANCE_REGISTRY_PATH=/app/data/instances/registry.json
PANEL_ROOT=/app/

# Java runtime for Minecraft servers
JAVA_PATH=java
JAVA_ARGS=-XX:MaxRAMPercentage=90.0 -XX:+UseG1GC

# Public endpoint shown in the panel (Tailscale)
# En Docker sin red host, pon tu IP 100.x aqui:
PUBLIC_HOST=
PUBLIC_PORT=25565
MC_PUBLIC_PORT=25565
TAILSCALE_IP=
